#
# Ekomobil payment configuration template
# Copy needed lines into apps/web/.env (do not keep duplicate keys).
#
# Rules:
# 1) Every KAPITAL_BANK_* key must exist only once.
# 2) In production, do not use test/sandbox API base URL.
# 3) Keep secrets out of git.
#

# Shared
KAPITAL_BANK_MERCHANT_ID=
KAPITAL_BANK_TERMINAL_ID=
KAPITAL_BANK_USERNAME=
KAPITAL_BANK_PASSWORD=
KAPITAL_BANK_SECRET=

# --- Staging / test mode ---
# KAPITAL_BANK_MODE=mock
# KAPITAL_BANK_API_BASE_URL=https://txpgtst.kapitalbank.az/api

# --- Production live mode ---
# KAPITAL_BANK_MODE=live
# KAPITAL_BANK_API_BASE_URL=https://<bank-live-endpoint>/api

# Optional emergency switch (keep false by default)
KAPITAL_BANK_ALLOW_SANDBOX_IN_LIVE=false
