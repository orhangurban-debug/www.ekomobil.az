{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/auction-sla-reminders",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/expire-listings",
      "schedule": "0 6,18 * * *"
    }
  ]
}
