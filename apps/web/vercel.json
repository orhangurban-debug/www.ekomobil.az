{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "nextjs",
  "installCommand": "npm install",
  "buildCommand": "npm run build",
  "crons": [
    {
      "path": "/api/cron/auction-sla-reminders",
      "schedule": "*/10 * * * *"
    },
    {
      "path": "/api/cron/expire-listings",
      "schedule": "0 6,18 * * *"
    },
    {
      "path": "/api/cron/archive-support-requests",
      "schedule": "0 3 * * *"
    },
    {
      "path": "/api/cron/escalate-user-reports",
      "schedule": "0 4 * * *"
    }
  ]
}
