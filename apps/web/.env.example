DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ekomobil?sslmode=disable"
# Production üçün mütləq təyin edin. Məs: openssl rand -hex 32
AUTH_SECRET="replace-with-long-random-secret"
# AI köməkçi üçün: https://aistudio.google.com/apikey
GEMINI_API_KEY=""
NEXT_PUBLIC_APP_URL="http://localhost:3000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
AUCTION_API_BASE_URL="http://127.0.0.1:4001"
AUCTION_API_INTERNAL_SECRET="replace-with-shared-secret"
AUCTION_DIRECT_BID_PATH="enabled"
# Production-da false saxlayın ki in-memory fallback bağlansın
AUCTION_ALLOW_MEMORY_FALLBACK="true"
PG_POOL_MAX="10"
PG_IDLE_TIMEOUT_MS="30000"
PG_CONNECTION_TIMEOUT_MS="5000"
REDIS_URL="redis://127.0.0.1:6379"
# Auksion lot sənədləri: production-da Vercel Blob token (private fayllar). Development üçün avtomatik lokal qovluq.
BLOB_READ_WRITE_TOKEN=""
# İstəyə görə: local | vercel_blob (və ya blob). Production serverless-də adətən token tələb olunur.
# Öz serverinizdə disk saxlama üçün: AUCTION_DOCUMENT_STORAGE=local
AUCTION_DOCUMENT_STORAGE=""
# Lokal disk root (yalnız AUCTION_DOCUMENT_STORAGE=local və ya development)
AUCTION_DOCUMENTS_DIR=""
# Kapital Bank skeleton üçün:
# disabled: yalnız daxili placeholder checkout
# mock: test üçün mock success/fail
# live: real merchant məlumatları ilə bank redirect
# Qeyd: live rejimdə hosted redirect provider context hazırlanır; bankın yekun request field mapping-i merchant onboarding-dən sonra tamamlanır.
KAPITAL_BANK_MODE="disabled"
KAPITAL_BANK_MERCHANT_ID=""
KAPITAL_BANK_TERMINAL_ID=""
KAPITAL_BANK_USERNAME=""
KAPITAL_BANK_PASSWORD=""
KAPITAL_BANK_SECRET=""
# İstəyə görə override. Default prod host: https://e-commerce.kapitalbank.az
KAPITAL_BANK_API_BASE_URL=""
# Vercel cron endpoint qoruması üçün məxfi token (məs: openssl rand -hex 32)
CRON_SECRET=""
# SLA reminder parametrləri (opsional override)
AUCTION_SLA_CONFIRMATION_HOURS="24"
AUCTION_SLA_PAYMENT_HOURS="12"
AUCTION_SLA_REMINDER_LEAD_MINUTES="60"
