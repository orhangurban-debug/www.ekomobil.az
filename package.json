{
  "name": "ekomobil-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*"
  ],
  "scripts": {
    "dev": "npm run dev:web",
    "dev:clean": "npm run dev:clean --workspace @ekomobil/web",
    "dev:web": "npm run dev --workspace @ekomobil/web",
    "dev:auction": "npm run dev --workspace auction-api",
    "compose:auction": "docker compose -f docker-compose.auction.yml up -d",
    "compose:auction:down": "docker compose -f docker-compose.auction.yml down",
    "build:web": "npm run build --workspace @ekomobil/web",
    "build:auction": "npm run build --workspace auction-api",
    "lint:web": "npm run lint --workspace @ekomobil/web",
    "db:migrate": "npm run db:migrate --workspace @ekomobil/web",
    "deploy:prep": "node scripts/deploy-prep.mjs",
    "loadtest:browse": "k6 run scripts/load-tests/k6/browse.js",
    "loadtest:mixed": "k6 run scripts/load-tests/k6/mixed-users.js",
    "loadtest:bids": "k6 run scripts/load-tests/k6/hot-auction-bids.js"
  }
}
