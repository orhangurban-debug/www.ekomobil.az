DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ekomobil?sslmode=disable"
# Production recommendation: point this to the same managed Postgres cluster as apps/web.
# Current baseline for this project is Neon Launch.
REDIS_URL="redis://127.0.0.1:6379"
# Production-da məcburidir; auction-api ilə eyni regionda saxlayın.
APP_URL="http://localhost:3000"
AUCTION_API_ALLOWED_ORIGINS="http://localhost:3000"
AUCTION_API_INTERNAL_SECRET="replace-with-shared-secret"
AUCTION_API_PORT="4001"
# Təhlükəsiz başlanğıc nöqtəsi; yalnız DB limitləri imkan verirsə artırın.
AUCTION_API_PG_POOL_MAX="20"
AUCTION_SSE_HEARTBEAT_MS="15000"
AUCTION_ANTI_SNIPING_WINDOW_MS="300000"
AUCTION_ANTI_SNIPING_EXTENSION_MS="120000"
AUCTION_STREAM_HISTORY_LIMIT="50"
